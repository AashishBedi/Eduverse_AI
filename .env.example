# EduVerse AI – Environment Configuration Template
# ─────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Fill every value marked FILL_THIS
#   3. Never commit .env to Git

# ── Application ───────────────────────────────────
APP_NAME=EduVerse AI
DEBUG=True

# ── Database ──────────────────────────────────────
DATABASE_URL=sqlite:///./eduverse.db

# ── JWT Authentication ────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=FILL_THIS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_TOKEN_EXPIRE_MINUTES=15

# ── Default Admin Account (first-run seed) ────────
# Change immediately after first login
ADMIN_DEFAULT_EMAIL=FILL_THIS
ADMIN_DEFAULT_PASSWORD=FILL_THIS

# ── Groq API Key ──────────────────────────────────
# Free key at: https://console.groq.com → API Keys → Create
GROQ_API_KEY=FILL_THIS
GROQ_MODEL=llama-3.1-70b-versatile

# ── CORS Origins (comma-separated) ───────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Vector Store ──────────────────────────────────
VECTOR_STORE_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=eduverse_documents

# ── Evaluation Logging ────────────────────────────
ENABLE_EVALUATION_LOGGING=True
EVALUATION_LOG_PATH=./data/evaluation_logs
